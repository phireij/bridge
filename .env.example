# Bridge environment variables
#
# Bridge's dashboard runs on seeded data with no env vars. The Operation
# Anniversary reservation system (Ruby) needs Supabase — fill these in to go live.

# ── Supabase (client-safe, exposed to the browser) ───────────────────────────
# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon/public key (RLS keeps the reservations table closed; customers
# only reach it through the get_availability() / book_reservation() functions)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only secrets (NEVER prefixed NEXT_PUBLIC; never sent to the client) ─
# Service-role key — used only in server actions / route handlers for staff
# admin reads & writes. Do NOT commit a real value. Do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Shared staff passcode for the reservation admin gate (server-verified only).
ADMIN_PASSCODE=

# ── Transactional email via Resend (server-only) ─────────────────────────────
# When both are set, /reserve exposes the optional email input and confirmation
# emails fire after DB-successful booking + admin approve/cancel actions.
# When missing on a deployed environment, the email input is HIDDEN entirely
# (CTO escape hatch) so we never collect addresses we cannot use.
#
# Sending API key (Resend → API Keys → Create; "Sending access", not Full).
RESEND_API_KEY=
# From address — either a bare email or "Display <email>" format. Must be a
# verified domain in Resend (e.g. rubyscakedelights.shop).
RESEND_FROM_EMAIL=
# Optional reply-to override; defaults to the from address when unset.
RESEND_REPLY_TO=

# ── Bridge Lite Operational HQ (Mission #002A, dedicated bridge-hq project) ──
# Separate Supabase project from the one above (which is for Ruby reservations
# only). Project id uwkxcbadxsuqgdrpkwmg, org jqyetjxpqgfmfkazzktw, ap-northeast-1.
# Get these three from the Supabase dashboard for the "bridge-hq" project —
# never commit real values.
NEXT_PUBLIC_BRIDGE_SUPABASE_URL=
NEXT_PUBLIC_BRIDGE_SUPABASE_ANON_KEY=
BRIDGE_SUPABASE_SERVICE_ROLE_KEY=
