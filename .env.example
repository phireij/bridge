# Bridge environment variables
#
# v0.1 runs entirely on seeded data — none of these are required to run the app.
# Fill them in when you swap the data-access layer (src/lib/data) over to live
# Supabase queries. See README.md → "The Data Layer (and how to go live)".

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
